# --- 项目基础设置 ---
PROJECT_NAME="智能交通问答系统"
API_V1_STR="/api/v1"

# --- 数据库配置 (修改为你自己的 MySQL 信息) ---
# 本地最小启动也可以直接改用 SQLite:
# SQLITE_URL=sqlite:///./traffic_agent.db
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=traffic_qa_db

# --- AI 模型配置 ---
# 如果是用 DeepSeek:
OPENAI_API_KEY=你的sk-xxxx密钥
OPENAI_BASE_URL=https://api.deepseek.com

# 如果是用 OpenAI (需要魔法):
# OPENAI_API_KEY=sk-xxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Redis 配置 ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# --- 高德服务配置 ---
AMAP_KEY=你的高德KEY
